# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streetbite

# JWT Configuration (for backward compatibility)
JWT_SECRET=dev-secret-key-change-in-production

# Firebase Admin SDK Configuration
# Get these from Firebase Console > Project Settings > Service Accounts
# Option 1: Use service account JSON (recommended for production)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Option 2: Use individual credentials (easier for development)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# SMS Configuration (Firebase handles this automatically)
# No additional SMS service needed when using Firebase Auth
